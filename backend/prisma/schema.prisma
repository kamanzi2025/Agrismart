// AgriSmart Advisor — Prisma Schema
// PostgreSQL 15 | Prisma ORM
// Run: npx prisma generate && npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────

enum Role {
  FARMER
  EXTENSION_OFFICER
  COOPERATIVE_LEADER
  ADMIN
}

enum Language {
  EN
  RW
}

enum PestReportStatus {
  PENDING
  ANALYZED
  RESOLVED
}

enum FinancialType {
  EXPENSE
  REVENUE
}

enum AdvisoryType {
  PLANTING
  PEST
  SOIL
  GENERAL
}

enum PestType {
  FUNGAL
  VIRAL
  BACTERIAL
  INSECT
}

enum SeverityLevel {
  LOW
  MEDIUM
  HIGH
}

// ─────────────────────────────────────────────────────────────────
// USER — Base model for all user types
// ─────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  phone        String   @unique
  passwordHash String
  role         Role
  /// JSON: { lat: Float, lng: Float, region: String }
  location     Json
  language     Language @default(EN)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  farmer               Farmer?             @relation("UserFarmer")
  cooperativesLed      Cooperative[]       @relation("CooperativeLeader")
  pestReportsAnalyzed  PestReport[]        @relation("AnalyzedBy")
  advisoriesSent       Advisory[]          @relation("OfficerAdvisory")
  farmersAssigned      Farmer[]            @relation("AssignedOfficer")
  auditLogs            AuditLog[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────
// FARMER — One-to-one with User
// ─────────────────────────────────────────────────────────────────

model Farmer {
  userId            String   @id
  farmSize          Float    // hectares
  soilType          String?
  cooperativeId     String?
  assignedOfficerId String?

  // Relations
  user              User            @relation("UserFarmer", fields: [userId], references: [id], onDelete: Cascade)
  cooperative       Cooperative?    @relation(fields: [cooperativeId], references: [id])
  assignedOfficer   User?           @relation("AssignedOfficer", fields: [assignedOfficerId], references: [id])
  pestReports       PestReport[]
  financialRecords  FinancialRecord[]
  advisories        Advisory[]

  @@map("farmers")
}

// ─────────────────────────────────────────────────────────────────
// COOPERATIVE
// ─────────────────────────────────────────────────────────────────

model Cooperative {
  id        String   @id @default(uuid())
  name      String
  region    String
  leaderId  String   // FK → User.id, must have role COOPERATIVE_LEADER
  createdAt DateTime @default(now())

  // Relations
  leader    User     @relation("CooperativeLeader", fields: [leaderId], references: [id])
  members   Farmer[]

  @@map("cooperatives")
}

// ─────────────────────────────────────────────────────────────────
// PEST REPORT
// ─────────────────────────────────────────────────────────────────

model PestReport {
  id                    String           @id @default(uuid())
  farmerId              String
  imagePath             String
  diagnosis             String?
  recommendation        String?
  status                PestReportStatus @default(PENDING)
  analyzedByOfficerId   String?
  createdAt             DateTime         @default(now())

  // Relations
  farmer                Farmer           @relation(fields: [farmerId], references: [userId], onDelete: Cascade)
  analyzedByOfficer     User?            @relation("AnalyzedBy", fields: [analyzedByOfficerId], references: [id])

  @@map("pest_reports")
}

// ─────────────────────────────────────────────────────────────────
// FINANCIAL RECORD
// ─────────────────────────────────────────────────────────────────

model FinancialRecord {
  id          String        @id @default(uuid())
  farmerId    String
  type        FinancialType
  /// Seeds | Fertilizer | Labour | Transport | Bean Sale | Other
  category    String
  amount      Decimal       @db.Decimal(12, 2)
  description String?
  date        DateTime
  season      String        // e.g. "Season A 2025"
  /// UUID v4 set by client — used for offline sync deduplication
  clientUUID  String        @unique
  createdAt   DateTime      @default(now())

  // Relations
  farmer      Farmer        @relation(fields: [farmerId], references: [userId], onDelete: Cascade)

  @@index([farmerId, season])
  @@index([farmerId, type])
  @@map("financial_records")
}

// ─────────────────────────────────────────────────────────────────
// ADVISORY
// ─────────────────────────────────────────────────────────────────

model Advisory {
  id            String       @id @default(uuid())
  farmerId      String
  officerId     String?
  type          AdvisoryType
  content       String
  isAutomated   Boolean      @default(false)
  isRead        Boolean      @default(false)
  dateGenerated DateTime     @default(now())

  // Relations
  farmer        Farmer       @relation(fields: [farmerId], references: [userId], onDelete: Cascade)
  officer       User?        @relation("OfficerAdvisory", fields: [officerId], references: [id])

  @@index([farmerId, isRead])
  @@map("advisories")
}

// ─────────────────────────────────────────────────────────────────
// PLANTING CALENDAR
// ─────────────────────────────────────────────────────────────────

model PlantingCalendar {
  id        String   @id @default(uuid())
  region    String
  season    String
  startDate DateTime
  endDate   DateTime
  notes     String?

  @@unique([region, season])
  @@map("planting_calendars")
}

// ─────────────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid())
  userId       String
  action       String
  resourceType String
  resourceId   String
  timestamp    DateTime @default(now())
  /// Additional context (IP, request body snapshot, etc.)
  metadata     Json?

  // Relations
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([timestamp])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}
